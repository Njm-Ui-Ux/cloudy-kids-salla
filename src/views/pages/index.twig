{#
| Variable       | Type     | Description
|----------------|----------|-------------------------------
| page           | object   |
| page.title     | string   | *could be html
| page.slug      | string   | ex: "cat.show"
#}

{% extends "layouts.master" %}

{% block content %}

<main class="ck-page" id="home">

  <section class="ck-hero-v2">
    <div class="ck-hero-v2__cloud ck-hero-v2__cloud--one"></div>
    <div class="ck-hero-v2__cloud ck-hero-v2__cloud--two"></div>
    <div class="ck-hero-v2__cloud ck-hero-v2__cloud--three"></div>

    <div class="ck-container">
      <div class="ck-hero-v2__panel">

        <div class="ck-hero-v2__content">
          <span class="ck-pill">
            مختارات ناعمة بحب
          </span>

          <h1 class="ck-hero-v2__title">
            عالم طفلك
            <span>بكل حب</span>
          </h1>

          <p class="ck-hero-v2__text">
            منتجات آمنة، ناعمة، ومختارة بعناية لتصنع لطفلك راحة أجمل، وتجربة تسوق هادئة للأم والعائلة في كل لحظة.
          </p>

          <div class="ck-hero-v2__actions">
            <a href="#products" class="ck-btn-v2 ck-btn-v2--primary">
              تسوق الآن
            </a>

            <a href="#categories" class="ck-btn-v2 ck-btn-v2--secondary">
              اكتشف الفئات
            </a>
          </div>
        </div>

        <div class="ck-hero-v2__visual">
          <div class="ck-scene">
            <div class="ck-moon"></div>
            <div class="ck-star ck-star--one"></div>
            <div class="ck-star ck-star--two"></div>
            <div class="ck-balloon"></div>

            <div class="ck-cloud-bed ck-cloud-bed--one"></div>
            <div class="ck-cloud-bed ck-cloud-bed--two"></div>
            <div class="ck-cloud-bed ck-cloud-bed--three"></div>

            <div class="ck-teddy">
              <span class="ck-teddy__ear ck-teddy__ear--left"></span>
              <span class="ck-teddy__ear ck-teddy__ear--right"></span>
              <span class="ck-teddy__head"></span>
              <span class="ck-teddy__body"></span>
              <span class="ck-teddy__arm ck-teddy__arm--left"></span>
              <span class="ck-teddy__arm ck-teddy__arm--right"></span>
              <span class="ck-teddy__foot ck-teddy__foot--left"></span>
              <span class="ck-teddy__foot ck-teddy__foot--right"></span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="ck-category-strip" id="categories">
    <div class="ck-container">
      <div class="ck-category-strip__grid">

        <a href="#products" class="ck-icon-category">
          <span class="ck-icon-category__icon">🎁</span>
          <strong>الهدايا</strong>
        </a>

        <a href="#products" class="ck-icon-category">
          <span class="ck-icon-category__icon">📚</span>
          <strong>الكتب</strong>
        </a>

        <a href="#products" class="ck-icon-category">
          <span class="ck-icon-category__icon">🏠</span>
          <strong>المنزل</strong>
        </a>

        <a href="#products" class="ck-icon-category">
          <span class="ck-icon-category__icon">🌙</span>
          <strong>النوم</strong>
        </a>

        <a href="#products" class="ck-icon-category">
          <span class="ck-icon-category__icon">🍼</span>
          <strong>الرضاعة</strong>
        </a>

        <a href="#products" class="ck-icon-category">
          <span class="ck-icon-category__icon">🧸</span>
          <strong>الألعاب</strong>
        </a>

        <a href="#products" class="ck-icon-category">
          <span class="ck-icon-category__icon">👗</span>
          <strong>الملابس</strong>
        </a>

        <a href="#products" class="ck-icon-category ck-icon-category--all">
          <span class="ck-icon-category__icon">☰</span>
          <strong>كل الفئات</strong>
        </a>

      </div>
    </div>
  </section>

  <section class="ck-products-area" id="products">
    <div class="ck-container">
      <div class="ck-section-title">
        <span>منتجات مميزة</span>
        <h2>اختيارات ناعمة لطفلك</h2>
      </div>
    </div>

    <div class="ck-products-native">
      {% component home %}
    </div>
  </section>

  <section class="ck-offer-banner">
    <div class="ck-container">
      <div class="ck-offer-banner__panel">
        <div class="ck-offer-banner__side">
          <span>خصم</span>
          <strong>20%</strong>
          <small>على مجموعة مختارة</small>
        </div>

        <div class="ck-offer-banner__main">
          <span class="ck-pill ck-pill--light">عرض لفترة محدودة</span>
          <h2>عالم من العناية والحب</h2>
          <p>لأن طفلك يستحق الأفضل دائمًا، اخترنا لك منتجات ناعمة بتجربة تسوق أكثر هدوءًا وأناقة.</p>
        </div>

        <a href="#products" class="ck-btn-v2 ck-btn-v2--primary">
          تسوق العرض
        </a>
      </div>
    </div>
  </section>

  <section class="ck-new-arrivals">
    <div class="ck-container">
      <div class="ck-section-title">
        <span>وصل حديثًا</span>
        <h2>لمسات جديدة لعالم طفلك</h2>
      </div>

      <div class="ck-arrival-grid">
        <div class="ck-arrival-card">
          <span class="ck-arrival-card__icon">🧸</span>
          <strong>دمى ناعمة</strong>
          <small>لمسة لطيفة لكل يوم</small>
        </div>

        <div class="ck-arrival-card">
          <span class="ck-arrival-card__icon">🍼</span>
          <strong>رضاعات وأدوات</strong>
          <small>اختيارات عملية وآمنة</small>
        </div>

        <div class="ck-arrival-card">
          <span class="ck-arrival-card__icon">👕</span>
          <strong>ملابس يومية</strong>
          <small>ألوان هادئة ومريحة</small>
        </div>

        <div class="ck-arrival-card">
          <span class="ck-arrival-card__icon">🎲</span>
          <strong>ألعاب تعليمية</strong>
          <small>متعة واكتشاف</small>
        </div>
      </div>
    </div>
  </section>

  <section class="ck-trust-row">
    <div class="ck-container">
      <div class="ck-trust-row__panel">
        <div class="ck-trust-box">
          <span>🚚</span>
          <strong>شحن سريع</strong>
          <small>تجربة توصيل مريحة</small>
        </div>

        <div class="ck-trust-box">
          <span>🛡️</span>
          <strong>منتجات آمنة</strong>
          <small>مختارة بعناية</small>
        </div>

        <div class="ck-trust-box">
          <span>💎</span>
          <strong>جودة مصممة</strong>
          <small>نهتم بكل تفصيلة</small>
        </div>

        <div class="ck-trust-box">
          <span>🎧</span>
          <strong>دعم العملاء</strong>
          <small>نحن هنا لمساعدتك</small>
        </div>
      </div>
    </div>
  </section>

  <section class="ck-testimonials">
    <div class="ck-container">
      <div class="ck-section-title">
        <span>ماذا يقول عملاؤنا؟</span>
        <h2>تجربة لطيفة وموثوقة</h2>
      </div>

      <div class="ck-testimonial-grid">
        <div class="ck-testimonial-card">
          <p>جودة المنتجات رائعة والتجربة سهلة جدًا، أحببت هدوء التصميم وسرعة الوصول للمنتجات.</p>
          <div>
            <strong>أمل السبيعي</strong>
            <span>★★★★★</span>
          </div>
        </div>

        <div class="ck-testimonial-card">
          <p>المتجر مرتب وواضح، المنتجات تظهر بشكل جميل والشراء كان بسيطًا من الجوال.</p>
          <div>
            <strong>سارة الحربي</strong>
            <span>★★★★★</span>
          </div>
        </div>

        <div class="ck-testimonial-card">
          <p>أحببت الألوان الهادئة وطريقة عرض المنتجات، تجربة مناسبة جدًا لمتجر أطفال.</p>
          <div>
            <strong>نورة العتيبي</strong>
            <span>★★★★★</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="ck-newsletter">
    <div class="ck-container">
      <div class="ck-newsletter__panel">
        <div>
          <span class="ck-pill ck-pill--light">اشترك في نشرتنا</span>
          <h2>كن أول من يعرف بالعروض الجديدة</h2>
          <p>احصل على أخبار المنتجات والعروض الناعمة أولًا بأول.</p>
        </div>

        <form class="ck-newsletter__form" action="#">
          <input type="email" placeholder="ادخل بريدك الإلكتروني">
          <button type="submit">اشتراك</button>
        </form>
      </div>
    </div>
  </section>

</main>

{% endblock %}

{% block scripts %}
  <script defer src="{{ 'home.js' | asset }}"></script>
{% endblock %}